# Same Railway database as fieldops-core
DATABASE_URL=postgresql://postgres:...@shuttle.proxy.rlwy.net:24094/railway

# API server port (different from fieldops-core's 3000)
API_PORT=4000
NODE_ENV=production
APP_URL=https://stiltheights.com

# WhatsApp (same keys as fieldops-core)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Payments (same keys as fieldops-core)
OXAPAY_MERCHANT_KEY=
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=

# Admin — to create API keys
SETUP_SECRET=same_as_fieldops_core
